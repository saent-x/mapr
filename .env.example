# Server (Railway, Fly, VPS, etc.)
ADMIN_PASSWORD=your-admin-password
# Optional: separate secret for signed admin cookies (defaults to ADMIN_PASSWORD)
# ADMIN_SESSION_SECRET=

PORT=3030                          # Many hosts set this automatically

# Optional: data directory (default: ./data)
# MAPR_DATA_DIR=/app/data

# Optional: refresh interval (default: 10 minutes)
# MAPR_REFRESH_MS=600000

# Optional: live ship positions (AISStream.io)
# AISSTREAM_API_KEY=

# Frontend build: only if the browser calls a different API origin than the static app
# VITE_MAPR_API_BASE=https://api.example.com/api
