# Server (Railway, Fly, VPS, etc.)
ADMIN_PASSWORD=your-admin-password
# Optional: separate secret for signed admin cookies (defaults to ADMIN_PASSWORD)
# ADMIN_SESSION_SECRET=

PORT=3030                          # Many hosts set this automatically

# Optional: data directory (default: ./data)
# MAPR_DATA_DIR=/app/data

# Optional: refresh interval (default: 10 minutes)
# MAPR_REFRESH_MS=600000

# Postgres size cap. Trim oldest articles when DB exceeds soft limit.
# Limits derive from plan capacity × percentages so they track the active tier.
# Defaults: capacity 5120 MB (5 GB), trim at 90% = 4608 MB, hard at 95% = 4864 MB,
# target = (trim% − 5) = 85% = 4352 MB.
# MAPR_DB_CAPACITY_MB=5120       # plan capacity in MB (5 GB default)
# MAPR_DB_TRIM_PERCENT=90        # soft-trim trigger (% of capacity)
# MAPR_DB_HARD_PERCENT=95        # aggressive-batch trigger (% of capacity)
# Explicit MB overrides win over the percentage derivation:
# MAPR_DB_SIZE_LIMIT_MB=         # override soft ceiling (MB)
# MAPR_DB_SIZE_TARGET_MB=        # override trim target (MB)
# MAPR_DB_SIZE_HARD_MB=          # override hard ceiling (MB)
# MAPR_DB_TRIM_BATCH=1000        # rows deleted per pass

# Feature flag: enable flight/ship tracking (set to "true" to enable)
# ENABLE_TRACKING=true
# VITE_ENABLE_TRACKING=true

# Optional: OpenSky Network authenticated access (higher rate limits)
# OPENSKY_CLIENT_ID=
# OPENSKY_CLIENT_SECRET=

# Optional: live ship positions (AISStream.io)
# AISSTREAM_API_KEY=

# Frontend build: only if the browser calls a different API origin than the static app
# VITE_MAPR_API_BASE=https://api.example.com/api
