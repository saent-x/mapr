# Server (Railway, Fly, VPS, etc.)
ADMIN_PASSWORD=your-admin-password
# Optional: separate secret for signed admin cookies (defaults to ADMIN_PASSWORD)
# ADMIN_SESSION_SECRET=

PORT=3030                          # Many hosts set this automatically

# Optional: data directory (default: ./data)
# MAPR_DATA_DIR=/app/data

# Optional: refresh interval (default: 10 minutes)
# MAPR_REFRESH_MS=600000

# Postgres size cap. Trim oldest articles when DB exceeds limit.
# Default soft limit 400 MB, hard ceiling 500 MB (Neon free tier).
# MAPR_DB_SIZE_LIMIT_MB=400
# MAPR_DB_SIZE_TARGET_MB=350     # trim down to this (default = limit - 50)
# MAPR_DB_SIZE_HARD_MB=500       # aggressive trim above this
# MAPR_DB_TRIM_BATCH=1000        # rows deleted per pass

# Feature flag: enable flight/ship tracking (set to "true" to enable)
# ENABLE_TRACKING=true
# VITE_ENABLE_TRACKING=true

# Optional: OpenSky Network authenticated access (higher rate limits)
# OPENSKY_CLIENT_ID=
# OPENSKY_CLIENT_SECRET=

# Optional: live ship positions (AISStream.io)
# AISSTREAM_API_KEY=

# Frontend build: only if the browser calls a different API origin than the static app
# VITE_MAPR_API_BASE=https://api.example.com/api
