# Railway deployment
ADMIN_PASSWORD=your-admin-password
PORT=3030                          # Railway sets this automatically
DATABASE_URL=postgresql://user:pass@host:5432/mapr

# Optional: data directory (default: ./data)
# MAPR_DATA_DIR=/app/data

# Optional: refresh interval (default: 10 minutes)
# MAPR_REFRESH_MS=600000

# Optional: Upstash Redis for source catalog (falls back to Postgres metadata table)
# KV_REST_API_URL=https://your-upstash-instance.upstash.io
# KV_REST_API_TOKEN=your-token
